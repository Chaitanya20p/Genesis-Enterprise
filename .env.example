# ============================================================
#  Genesis AI — Environment Configuration Template
#  Copy this file to .env and fill in your real credentials.
#  NEVER commit your actual .env file to version control.
# ============================================================

# --- IBM Watsonx.ai Credentials ---
# Obtain from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=QUlqeKuJUkbwh9BT-P6hT4CPel7WM8hC22LXcF8SlDPl

# Watsonx.ai Project ID (from your IBM Cloud Watsonx project settings)
PROJECT_ID=fda826b0-7ca4-4635-898f-c6f7f94818d4

# IBM Cloud regional endpoint for Watsonx.ai inference
IBM_CLOUD_URL=https://au-syd.dai.cloud.ibm.com

# --- Flask Application Settings ---
# Secret key for session signing — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_a_strong_random_secret_key

# Set to "development" for debug mode, "production" for deployment
FLASK_ENV=development

# --- Database Configuration ---
# SQLite path for local development; swap for PostgreSQL URI in production
DATABASE_URL=sqlite:///genesis_projects.db

# --- ChromaDB Vector Store ---
# Local directory path where ChromaDB persists its vector index
CHROMA_DB_PATH=./chroma_store

# --- PDF Export (wkhtmltopdf) ---
# Path to the wkhtmltopdf binary used by pdfkit
# macOS (Homebrew): /usr/local/bin/wkhtmltopdf
# Linux:            /usr/bin/wkhtmltopdf
WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf

# --- File Upload Settings ---
# Directory for storing uploaded PDFs for RAG processing
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH_MB=16
